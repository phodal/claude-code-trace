{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claude Code Hooks Trace Record",
  "description": "Schema for trace records generated by Claude Code Hooks",
  "type": "object",
  "required": ["version", "event_type", "timestamp"],
  "properties": {
    "version": {
      "type": "string",
      "description": "Trace schema version",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "example": "0.1.0"
    },
    "event_type": {
      "type": "string",
      "description": "Type of hook event",
      "enum": [
        "session_start",
        "session_stop",
        "pre_tool_use",
        "post_tool_use",
        "notification"
      ]
    },
    "session_id": {
      "type": "string",
      "description": "Unique identifier for the Claude Code session"
    },
    "span_id": {
      "type": "string",
      "description": "Unique identifier for a tool use span (links pre and post events)"
    },
    "timestamp": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 timestamp when the event occurred"
    },
    "context": {
      "type": "object",
      "description": "Session context information (present in session_start)",
      "properties": {
        "project_dir": {
          "type": "string",
          "description": "Absolute path to the project directory"
        },
        "vcs": {
          "$ref": "#/definitions/vcs"
        }
      }
    },
    "tool": {
      "type": "object",
      "description": "Tool information (present in tool use events)",
      "properties": {
        "name": {
          "type": "string",
          "description": "Name of the tool (Write, Edit, Bash, etc.)"
        },
        "input": {
          "type": "object",
          "description": "Input parameters passed to the tool"
        },
        "output": {
          "type": "object",
          "description": "Output returned by the tool (post_tool_use only)"
        }
      }
    },
    "file": {
      "type": "object",
      "description": "File information (present when tool operates on files)",
      "properties": {
        "path": {
          "type": "string",
          "description": "Relative path to the file from project root"
        },
        "exists": {
          "type": "boolean",
          "description": "Whether the file exists after the operation"
        },
        "line_count": {
          "type": "integer",
          "description": "Number of lines in the file"
        },
        "git_status": {
          "type": "string",
          "description": "Git status indicator (M=modified, A=added, etc.)"
        }
      }
    },
    "file_path": {
      "type": "string",
      "description": "Quick reference to file path (pre_tool_use)"
    },
    "notification": {
      "type": "object",
      "description": "Notification details (notification events only)",
      "properties": {
        "type": {
          "type": "string",
          "description": "Type of notification"
        },
        "title": {
          "type": "string"
        },
        "message": {
          "type": "string"
        }
      }
    },
    "summary": {
      "type": "object",
      "description": "Session summary (session_stop only)",
      "properties": {
        "event_count": {
          "type": "integer",
          "description": "Total number of events in the session"
        },
        "duration_seconds": {
          "type": "number",
          "description": "Session duration in seconds"
        },
        "git_changes": {
          "type": "string",
          "description": "Git diff summary"
        }
      }
    },
    "trace_file": {
      "type": "string",
      "description": "Path to the trace file (session_start only)"
    }
  },
  "definitions": {
    "vcs": {
      "type": "object",
      "properties": {
        "type": {
          "type": "string",
          "enum": ["git"],
          "description": "Version control system type"
        },
        "commit": {
          "type": "string",
          "description": "Current commit SHA"
        },
        "branch": {
          "type": "string",
          "description": "Current branch name"
        }
      }
    }
  }
}

